# Primary DB. Local: mongodb://127.0.0.1:27017/blog_moderation
# Atlas: if mongodb+srv fails with querySrv ECONNREFUSED, use the standard mongodb://… string from Atlas (not +srv).
MONGODB_URI=
# Optional: second database for approved posts only (collection published_blogs). Same or different cluster as above.
MAIN_SITE_MONGODB_URI=
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h
PORT=5000
# Comma-separated browser origins (also supports legacy FRONTEND_ORIGIN for one host)
CORS_ORIGINS=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
NODE_ENV=development



